# ---------- 前端静态文件 ----------
# 指向编译后的 dist 目录
FRONTEND_DIR=../frontend/dist

# ---------- ComfyUI 服务地址 ----------
COMFYUI_URL=http://127.0.0.1:8188

# ---------- 标签搜索 API 地址（需单独部署标签搜索服务） ----------
TAG_API_URL=http://127.0.0.1:8001/search

# ---------- 服务端口和地址 ----------
SERVER_PORT=9988
SERVER_HOST=127.0.0.1

# ---------- 跨域配置 ----------
# 生产环境改成你的正式域名，多个来源用逗号分隔
CORS_ORIGINS=https://XXX.XXX.XXX.XXX

# ---------- 管理接口 API Key ----------
# 保护 /api/admin/* 管理接口，请求头需携带 X-API-Key: <此值>
# 用途：生成兑换码、查看兑换记录、增删模型/LoRA 等管理操作
# 请替换为随机字符串
ADMIN_API_KEY=your_secure_api_key_here

# ---------- 用户令牌签名密钥 ----------
# 签发 HttpOnly Cookie 令牌，用于用户身份鉴权
# 生产环境必须设置为随机字符串；更换密钥会使所有已签发 Cookie 失效
# 请替换为随机字符串
USER_TOKEN_SECRET=generate_a_random_secret_key_here

# ---------- Cookie 安全配置 ----------
# 生产环境启用 HTTPS 时设为 true，Cookie 将仅通过 HTTPS 传输
COOKIE_SECURE=false

# ---------- 兑换码频率限制 ----------
REDEEM_RATE_LIMIT=10
REDEEM_RATE_WINDOW=60

# ---------- 并发与冷却 ----------
# 最大并发任务数
MAX_CONSECUTIVE_TASKS=2
# 冷却算法: cooldown = min(BASE + queue_length * MULTIPLIER, MAX)
# 队列越长冷却越久，防止排队时用户疯狂提交
COOLDOWN_BASE=4
COOLDOWN_QUEUE_MULTIPLIER=2
COOLDOWN_MAX=20
# 本地 IP 冷却倍率（0 = 无冷却，1 = 与远程相同，0.5 = 远程的一半）
COOLDOWN_LOCAL_RATIO=0.4

# ---------- 图片配置 ----------
# WebP 压缩质量（1-100，越高画质越好但文件越大）
WEBP_QUALITY=90
# 生图尺寸范围
IMAGE_MIN_SIZE=512
IMAGE_MAX_SIZE=2048

# ---------- 新用户初始额度 ----------
# 新注册用户获得的初始生图额度
INITIAL_QUOTA=99

# ---------- 数据库路径（可选） ----------
# 默认在 backend/ 目录下生成 app.db
# DB_PATH=app.db

# ---------- 每日赠礼配置 ----------
# 是否启用每日赠礼功能
DAILY_GIFT_ENABLED=true
# 兑换码生成时间（北京时间，支持 HH:MM 格式，如 14:20）
DAILY_GIFT_TIME=6:00
# 每日赠礼兑换码额度
DAILY_GIFT_QUOTA=99
# 用户通过每日赠礼获取的额度上限（不能超过此值）
DAILY_GIFT_MAX_QUOTA=99
# 兑换码有效期（小时）
DAILY_GIFT_VALID_HOURS=23
# 兑换码有效期（分钟）
DAILY_GIFT_VALID_MINUTES=59
